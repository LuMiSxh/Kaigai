{
    "name": "kaigai",
    "version": "1.0.0",
    "description": "Local Japanese livestream subtitles",
    "type": "module",
    "packageManager": "pnpm@11.11.0",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --all-features --locked",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run && python3 -m unittest discover scripts/tests",
        "test:watch": "vitest",
        "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --all-features --locked",
        "test:bench-tools": "python3 -m unittest discover scripts/tests",
        "bench:prepare": "node scripts/prepare-vtuber-corpus.mjs",
        "bench:prepare:reference": "python3 scripts/prepare-fleurs-corpus.py",
        "bench:models": "cargo run --manifest-path src-tauri/Cargo.toml --example bench_corpus --features benchmark --release",
        "bench:asr-mt:opus": "uv run scripts/translate-asr-mt.py",
        "bench:asr-mt:qwen": "uv run scripts/translate-asr-llm.py",
        "bench:compare": "python3 scripts/compare-benchmark-reports.py",
        "bench:score": "uv run scripts/score-benchmark-report.py",
        "bench:criterion": "cargo bench --manifest-path src-tauri/Cargo.toml --bench translation_corpus --features benchmark",
        "train:whisper": "uv run scripts/fine-tune-whisper.py",
        "bindings": "cargo test --manifest-path src-tauri/Cargo.toml --locked export_bindings",
        "tauri": "tauri"
    },
    "license": "MIT OR Apache-2.0",
    "dependencies": {
        "@tauri-apps/api": "^2.11.1",
        "anasthasia": "github:LuMiSxh/Anasthasia#v0.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-static": "^3.0.6",
        "@sveltejs/kit": "^2.9.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@tailwindcss/vite": "^4.3.0",
        "@tauri-apps/cli": "^2.11.4",
        "@types/node": "^24.0.0",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "prettier-plugin-svelte": "^4.1.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.3.0",
        "typescript": "~5.6.2",
        "typescript-eslint": "^8.61.0",
        "vite": "^6.0.3",
        "vitest": "^2.1.0"
    }
}
